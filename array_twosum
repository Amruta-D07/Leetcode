int* twoSum(int* nums, int numsSize, int target, int* returnSize) {
    int i,j;
    for(i=0;i<numsSize;i++){
        for(j=i+1;j<numsSize;j++){
             if(nums[i]==target-nums[j]){
                int* arr= (int *)malloc(2*sizeof(int));
                arr[0]=i;
                 arr[1]=j;
                 *returnSize=2;
                return arr;
            }      
        }
    }
    *returnSize=0;
    int *arr1=(int *)malloc(0*sizeof(int));
    return arr1;
}  
